{
  "name": "shaderbase",
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "packageManager": "bun@1.3.8",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build:registry": "node --experimental-strip-types scripts/build-registry.ts",
    "build:web": "cd apps/web && bun run build",
    "check": "bun run test && bun run typecheck && bun run validate:shaders && bun run build:web",
    "dev:web": "cd apps/web && bun run dev",
    "test": "node --experimental-strip-types packages/schema/src/index.test.ts",
    "typecheck": "tsc -p tsconfig.json",
    "validate:shaders": "node --experimental-strip-types scripts/validate-shaders.ts"
  },
  "devDependencies": {
    "nitro": "^3.0.1-20260227-181935-bfbb207c",
    "typescript": "^5.7.3",
    "zod": "^3.23.8"
  }
}
